        "jsCode": "const groqResponse = $input.first().json;\nconst rawContent = groqResponse.choices[0].message.content;\nconst parsed = JSON.parse(rawContent);\n\n// Pull the scoring data forward from the scoring node\nconst scoringData = $('Code in JavaScript').first().json;\n\nreturn {\n  json: {\n    ...scoringData,\n    explanation: parsed.explanation,\n    recommendation: parsed.recommendation\n  }\n};\n"
