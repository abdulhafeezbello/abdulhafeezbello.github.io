      "parameters": {
        "jsCode": "// === Loan Eligibility Scoring ===\nconst data = $input.first().json;\n\n// --- Normalize inputs ---\nconst income = Number(data[\"Income\"]) || 0;\nconst loanAmount = Number(data[\"Loan amount\"]) || 0;\nconst repaymentTermMonths = Number(data[\"Repayment term\"]) || 1;\nconst employmentTenureMonths = Number(data[\"Employment tenure\"]) || 0;\nconst dependents = Number(data[\"Number of dependants\"]) || 0;\nconst existingDebt = Number(data[\"Existing monthly debt obligations\"]) || 0;\nconst employmentStatus = (data[\"Employment status\"] || \"\").toLowerCase();\n\nconst found = data.found === true;\nconst totalLoans = Number(data.total_loans) || 0;\nconst loansRepaidOnTime = Number(data.loans_repaid_on_time) || 0;\nconst loansDefaulted = Number(data.loans_defaulted) || 0;\nconst activeLoanBalance = Number(data.active_loan_balance) || 0;\n\n// --- 1. Repayment history (max 40) ---\nlet repaymentScore = 0;\nif (!found || totalLoans === 0) {\n  repaymentScore = 20;\n} else {\n  const repaymentRate = loansRepaidOnTime / totalLoans;\n  const defaultRate = loansDefaulted / totalLoans;\n  repaymentScore = Math.round((repaymentRate * 40) - (defaultRate * 20));\n  repaymentScore = Math.max(0, Math.min(40, repaymentScore));\n}\n\n// --- 2. Debt-to-income (max 25) ---\nconst monthlyIncome = income / 12;\nconst estimatedMonthlyInstallment = loanAmount / repaymentTermMonths;\nconst totalMonthlyDebt = existingDebt + estimatedMonthlyInstallment + activeLoanBalance / repaymentTermMonths;\nconst dti = monthlyIncome > 0 ? totalMonthlyDebt / monthlyIncome : 1;\n\nlet dtiScore;\nif (dti <= 0.2) dtiScore = 25;\nelse if (dti <= 0.35) dtiScore = 18;\nelse if (dti <= 0.5) dtiScore = 10;\nelse dtiScore = 0;\n\n// --- 3. Employment stability (max 15) ---\nlet employmentScore = 0;\nif (employmentStatus === \"employed\" || employmentStatus === \"self-employed\") {\n  if (employmentTenureMonths >= 24) employmentScore = 15;\n  else if (employmentTenureMonths >= 12) employmentScore = 10;\n  else if (employmentTenureMonths >= 6) employmentScore = 5;\n  else employmentScore = 2;\n}\n\n// --- 4. Loan-to-income reasonableness (max 10) ---\nconst loanToIncomeRatio = income > 0 ? loanAmount / income : 999;\nlet loanSizeScore;\nif (loanToIncomeRatio <= 1) loanSizeScore = 10;\nelse if (loanToIncomeRatio <= 2) loanSizeScore = 6;\nelse if (loanToIncomeRatio <= 3) loanSizeScore = 3;\nelse loanSizeScore = 0;\n\n// --- 5. Dependents adjustment (max 10) ---\nlet dependentsScore;\nif (dependents === 0) dependentsScore = 10;\nelse if (dependents <= 2) dependentsScore = 7;\nelse if (dependents <= 4) dependentsScore = 4;\nelse dependentsScore = 1;\n\n// --- Total ---\nconst totalScore = repaymentScore + dtiScore + employmentScore + loanSizeScore + dependentsScore;\n\nlet riskCategory;\nif (totalScore >= 75) riskCategory = \"low\";\nelse if (totalScore >= 50) riskCategory = \"medium\";\nelse riskCategory = \"high\";\n\nreturn {\n  json: {\n    ...data,\n    score: totalScore,\n    risk_category: riskCategory,\n    score_breakdown: {\n      repayment_score: repaymentScore,\n      dti_score: dtiScore,\n      employment_score: employmentScore,\n      loan_size_score: loanSizeScore,\n      dependents_score: dependentsScore\n    },\n    debt_to_income_ratio: Math.round(dti * 100) / 100,\n    loan_to_income_ratio: Math.round(loanToIncomeRatio * 100) / 100,\n    estimated_monthly_installment: Math.round(estimatedMonthlyInstallment)\n  }\n};\n"
      },
